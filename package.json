{
  "name": "@lazy-tracker/cli",
  "version": "0.1.0",
  "description": "Lazy Tracker CLI - A command-line interface for Lazy Tracker",
  "type": "module",
  "bin": {
    "lt": "./dist/bin/lt.js"
  },
  "scripts": {
    "dev": "tsx bin/lt.ts",
    "build": "tsc",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-api": "rimraf src/api/__generated__ && tsx src/api/lib/generator.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "12.1.0",
    "conf": "12.0.0",
    "dotenv": "17.3.1",
    "open": "10.2.0",
    "ora": "8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.21.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "swagger-typescript-api": "^13.0.23",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "lazy-tracker",
    "cli",
    "project-management"
  ],
  "license": "MIT"
}
